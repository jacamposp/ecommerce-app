# Copy this file to `.env` and fill in the values below.
#   cp .env.example .env
# See the "Environment variables" section in README.md for where to get each one.

# PostgreSQL connection string (Prisma Postgres, Supabase, Neon, Railway, or a local Postgres instance all work).
DATABASE_URL="postgresql://user:password@localhost:5432/ecommerce_app"

# Base URL the app is served from. Used to build Stripe success/cancel redirect URLs.
# Keep this as localhost while developing; set it to your real domain in production.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth.js session/CSRF signing secret. Generate one with:
#   npx auth secret
# or
#   openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth credentials (Google Cloud Console → APIs & Services → Credentials → OAuth client ID → Web application).
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe API keys (Stripe Dashboard → Developers → API keys). Use the *test mode* secret key while developing.
STRIPE_SECRET_KEY="sk_test_..."

# Stripe webhook signing secret. While developing, run:
#   stripe listen --forward-to localhost:3000/api/webhooks/stripe --events checkout.session.completed,checkout.session.expired
# and copy the "whsec_..." value it prints. In production, create a webhook endpoint in the
# Stripe Dashboard instead and use the signing secret it gives you.
STRIPE_WEBHOOK_SECRET="whsec_..."

# Vercel Blob token, used by the admin panel to upload product images.
# Vercel Dashboard → Storage → Create Database → Blob → connect it to this project, then
# copy the token from the store's ".env.local" tab (or run `vercel env pull` if the project is linked).
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
